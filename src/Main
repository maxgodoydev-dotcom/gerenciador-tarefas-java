public class Main {
    public static void main(String[] args) {
        Gerenciador gerenciador = new Gerenciador();
        Menu menu = new Menu();
        int opcao = 0;

        do {
            menu.exibirMenuPrincipal();
            String entradaOpcao = menu.pedirTexto("");
            opcao = Validador.obterOpcaoValida(entradaOpcao);

            if (opcao == -1) {
                menu.exibirMensagem("Por favor, digite um número válido.");
                continue;
            }

            switch (opcao) {
                case 1:
                    String desc = menu.pedirTexto("Digite a descrição da tarefa: ");
                    gerenciador.adicionarTarefa(desc);
                    menu.exibirMensagem("Tarefa adicionada com sucesso!");
                    break;

                case 2:
                    menu.listarTarefas(gerenciador.getTarefas());
                    break;

                case 3:
                    menu.listarTarefas(gerenciador.getTarefas());
                    if (gerenciador.getTarefas().isEmpty()) break;
                    
                    String entradaIdxC = menu.pedirTexto("Digite o número da tarefa a concluir: ");
                    int idxC = Validador.obterOpcaoValida(entradaIdxC) - 1;
                    
                    if (gerenciador.isIndiceValido(idxC)) {
                        gerenciador.concluirTarefa(idxC);
                        menu.exibirMensagem("Tarefa concluída!");
                    } else {
                        menu.exibirMensagem("Índice inválido!");
                    }
                    break;

                case 4:
                    menu.listarTarefas(gerenciador.getTarefas());
                    if (gerenciador.getTarefas().isEmpty()) break;
                    
                    String entradaIdxR = menu.pedirTexto("Digite o número da tarefa a remover: ");
                    int idxR = Validador.obterOpcaoValida(entradaIdxR) - 1;
                    
                    if (gerenciador.isIndiceValido(idxR)) {
                        gerenciador.removerTarefa(idxR);
                        menu.exibirMensagem("Tarefa removida com sucesso!");
                    } else {
                        menu.exibirMensagem("Índice inválido!");
                    }
                    break;

                case 5:
                    menu.exibirMensagem("Saindo... Até mais!");
                    break;

                default:
                    menu.exibirMensagem("Opção inválida!");
            }
        } while (opcao != 5);
    }
}